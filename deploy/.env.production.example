# deploy/.env.production.example
#
# Production environment template for PreShift.
# Copy to /var/www/preshift/api/.env and fill in the secret values.

APP_NAME=PreShift
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://preshift86.com

FRONTEND_URL=https://preshift86.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=preshift
DB_USERNAME=preshift
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=database
CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=preshift86.com,www.preshift86.com

REVERB_APP_ID=preshift-prod
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=preshift86.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@preshift86.com
MAIL_FROM_NAME=PreShift

LOG_CHANNEL=stack
LOG_LEVEL=warning
